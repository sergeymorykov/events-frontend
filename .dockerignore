# === Существующие правила (оставляем) ===
node_modules
dist
build
.env*
*.log
.DS_Store
.vscode
.idea
*.swp
*.swo
Thumbs.db

# === 🔥 Новые критичные правила ===
# Системные и репозиторий
.git
.gitignore
*.md
LICENSE
docker-compose*.yml
Dockerfile*
.dockerignore

# Тесты и документация (не нужны в продакшен-образе)
**/*.test.*
**/*.spec.*
__tests__/
tests/
coverage/
*.test.js
*.spec.ts
docs/

# Конфигурации, не используемые в runtime
eslint.config.*
.prettierrc*
.stylelintrc*

# Изображения и ассеты исходников (если не копируются в dist)
src/assets/raw/
src/**/*.psd
src/**/*.fig
src/**/*.sketch

# Временные файлы ОС
*.tmp
*.temp
*.bak
*.swp
*.swo
*~